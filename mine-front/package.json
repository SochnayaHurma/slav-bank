{
  "name": "your-theme-blocks",
  "version": "1.0.0",
  "private": true,
  "description": "Build setup for custom Gutenberg blocks inside the theme",
  "scripts": {
    "start": "wp-scripts start blocks-bundle/index=src/blocks-bundle/index.js --blocks-manifest --webpack-copy-php",
    "start:hot": "wp-scripts start blocks-bundle/index=src/blocks-bundle/index.js --hot",
    "build": "wp-scripts build blocks-bundle/index=src/blocks-bundle/index.js --blocks-manifest --webpack-copy-php",
    "check:engines": "wp-scripts check-engines",
    "format": "wp-scripts format src",
    "lint:js": "wp-scripts lint-js src",
    "lint:css": "wp-scripts lint-style \"src/**/*.css\" \"src/**/*.scss\"",
    "lint:pkg": "wp-scripts lint-pkg-json",
    "packages:update": "wp-scripts packages-update",
    "audit:python-pages": "node scripts/python-page-audit.mjs"
  },
  "devDependencies": {
    "@wordpress/scripts": "^31.8.0"
  }
}
